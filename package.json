{
	"name": "pharo-language-server",
	"displayName": "Pharo Language Support",
	"description": "%extension.description%",
	"author": "Benoît Verhaeghe",
	"license": "MIT",
	"version": "2.2.0",
	"icon": "icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/badetitou/vscode-pharo"
	},
	"publisher": "badetitou",
	"categories": [
		"Formatters",
		"Programming Languages",
		"Snippets",
		"Debuggers",
		"Notebooks",
		"Testing"
	],
	"keywords": [
		"pharo",
		"smalltalk",
		"ston"
	],
	"engines": {
		"vscode": "^1.96.0"
	},
	"activationEvents": [
		"onDebugResolve:pharodb",
		"onFileSystem:pharoImage",
		"onNotebook:moosebook",
		"onChatParticipant:pharo-language-server.pharo"
	],
	"extensionDependencies": [
		"mindaro-dev.file-downloader",
		"badetitou.pharo-highlighter"
	],
	"main": "./dist/extension",
	"contributes": {
		"chatParticipants": [
			{
				"id": "pharo-language-server.pharo",
				"name": "pharo",
				"fullName": "Pharo",
				"description": "%chatParticipant.pharo.description%",
				"isSticky": true,
				"commands": [
					{
						"name": "help",
						"description": "%chatParticipant.pharo.command.help.description%"
					},
					{
						"name": "createPackage",
						"description": "%chatParticipant.pharo.command.createPackage.description%"
					},
					{
						"name": "createClass",
						"description": "%chatParticipant.pharo.command.createClass.description%"
					},
					{
						"name": "readClass",
						"description": "%chatParticipant.pharo.command.readClass.description%"
					},
					{
						"name": "listPackages",
						"description": "%chatParticipant.pharo.command.listPackages.description%"
					},
					{
						"name": "listClasses",
						"description": "%chatParticipant.pharo.command.listClasses.description%"
					},
					{
						"name": "eval",
						"description": "%chatParticipant.pharo.command.eval.description%"
					},
					{
						"name": "runClassTests",
						"description": "%chatParticipant.pharo.command.runClassTests.description%"
					},
					{
						"name": "runTest",
						"description": "%chatParticipant.pharo.command.runTest.description%"
					}
				]
			}
		],
		"languageModelTools": [
			{
				"name": "pharo-create-package",
				"displayName": "Pharo: créer un package",
				"modelDescription": "%lmTool.createPackage.modelDescription%",
				"tags": ["pharo", "smalltalk", "workspace", "create"],
				"inputSchema": {
					"type": "object",
					"properties": {
						"packageName": { "type": "string", "description": "%lmTool.createPackage.input.packageName.description%" }
					},
					"required": ["packageName"]
				}
			},
			{
				"name": "pharo-create-class",
				"displayName": "Pharo: créer une classe",
				"modelDescription": "%lmTool.createClass.modelDescription%",
				"tags": ["pharo", "smalltalk", "create"],
				"inputSchema": {
					"type": "object",
					"properties": {
						"packageName": { "type": "string" },
						"className": { "type": "string" },
						"superclassName": { "type": "string", "default": "Object" },
						"instanceVariables": { "type": "string", "description": "%lmTool.createClass.input.instanceVariables.description%" }
					},
					"required": ["packageName", "className"]
				}
			},
			{
				"name": "pharo-read-class",
				"displayName": "Pharo: lire une classe",
				"modelDescription": "%lmTool.readClass.modelDescription%",
				"tags": ["pharo", "smalltalk", "read"],
				"inputSchema": {
					"type": "object",
					"properties": {
						"className": { "type": "string" }
					},
					"required": ["className"]
				}
			},
			{
				"name": "pharo-list-packages",
				"displayName": "Pharo: lister les packages",
				"modelDescription": "%lmTool.listPackages.modelDescription%",
				"tags": ["pharo", "smalltalk", "read", "list"],
				"inputSchema": {
					"type": "object",
					"properties": {}
				}
			},
			{
				"name": "pharo-list-classes",
				"displayName": "Pharo: lister les classes",
				"modelDescription": "%lmTool.listClasses.modelDescription%",
				"tags": ["pharo", "smalltalk", "read", "list"],
				"inputSchema": {
					"type": "object",
					"properties": {
						"packageName": { "type": "string" }
					},
					"required": ["packageName"]
				}
			},
			{
				"name": "pharo-eval",
				"displayName": "Pharo: exécuter du code",
				"modelDescription": "%lmTool.eval.modelDescription%",
				"tags": ["pharo", "smalltalk", "execute"],
				"inputSchema": {
					"type": "object",
					"properties": {
						"code": { "type": "string" }
					},
					"required": ["code"]
				}
			},
			{
				"name": "pharo-run-class-tests",
				"displayName": "Pharo: exécuter tests de classe",
				"modelDescription": "%lmTool.runClassTests.modelDescription%",
				"tags": ["pharo", "smalltalk", "test"],
				"inputSchema": {
					"type": "object",
					"properties": {
						"className": { "type": "string" }
					},
					"required": ["className"]
				}
			},
			{
				"name": "pharo-run-test-method",
				"displayName": "Pharo: exécuter un test",
				"modelDescription": "%lmTool.runTestMethod.modelDescription%",
				"tags": ["pharo", "smalltalk", "test"],
				"inputSchema": {
					"type": "object",
					"properties": {
						"className": { "type": "string" },
						"testMethod": { "type": "string" }
					},
					"required": ["className", "testMethod"]
				}
			}
		],
		"configuration": {
			"type": "object",
			"title": "Pharo",
			"properties": {
				"pharo.pathToVM": {
					"title": "Path to VM",
					"scope": "window",
					"type": "string",
					"default": "pharo",
					"description": "%configuration.pharo.pathToVM.description%",
					"ignoreSync": true
				},
				"pharo.pathToImage": {
					"title": "Path to Image",
					"scope": "window",
					"type": "string",
					"default": "",
					"description": "%configuration.pharo.pathToImage.description%",
					"ignoreSync": true
				},
				"pharo.imageWorkspace": {
					"title": "Expose Pharo Image Workspace",
					"scope": "window",
					"type": "boolean",
					"default": false,
					"description": "%configuration.pharo.imageWorkspace.description%"
				},
				"pharo.headless": {
					"title": "Headless",
					"scope": "window",
					"type": "boolean",
					"default": "true",
					"description": "%configuration.pharo.headless.description%"
				},
				"pharo.debugMode": {
					"title": "Debug mode",
					"scope": "window",
					"type": "boolean",
					"default": "false",
					"description": "%configuration.pharo.debugMode.description%"
				},
				"pharo quick install.image name": {
					"title": "Quick install image name",
					"scope": "window",
					"type": "string",
					"default": "Moose64-12-PLS",
					"description": "%configuration.pharo.quickInstall.imageName.description%"
				},
				"pharo quick install.server version": {
					"title": "Quick install server version",
					"scope": "window",
					"type": "string",
					"default": "5.1.0",
					"description": "%configuration.pharo.quickInstall.serverVersion.description%"
				},
				"pharo quick install.server VM version": {
					"title": "Quick install server VM version",
					"scope": "window",
					"type": "string",
					"default": "120",
					"description": "%configuration.pharo.quickInstall.serverVmVersion.description%"
				},
				"pharoLanguageServer.trace.server": {
					"title": "Trace Level",
					"scope": "window",
					"type": "string",
					"enum": ["off","messages","verbose"],
                    "default": "off"
				}
			}
		},
		"views": {
			"pharoView": [
				{
					"id": "images",
					"name": "Pharo Images"
				},
				{
					"id": "pharoImage",
					"name": "Image Browser"
				},
				{
					"id": "pharoBindingView",
					"name": "Variables"
				}
			]
		},
		"icons": {
			"pls-icon": {
				"description": "%icons.plsIcon.description%",
				"default": {
					"fontPath": "res/pls-font.woff",
					"fontCharacter": "\\41"
				}
			},
			"moose-icon": {
				"description": "%icons.mooseIcon.description%",
				"default": {
					"fontPath": "res/pls-font.woff",
					"fontCharacter": "\\42"
				}
			}
		},
		"viewsWelcome": [
			{
				"view": "pharoBindingView",
				"contents": "Start by executing a selected piece of code with 'Ctrl + Alt + D'"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"icon": "media/pharo-bar.svg",
					"id": "pharoView",
					"title": "Pharo"
				}
			]
		},
		"languages": [
			{
				"id": "moosebook",
				"extensions": [
					".moosebook"
				],
				"icon": {
					"light": "./media/moose-logo.svg",
					"dark": "./media/moose-logo.svg"
				}
			}
		],
		"commands": [
			{
				"command": "pharo.browseImage",
				"title": "Browse Pharo Image",
				"enablement": "false"
			},
			{
				"command": "pharo.extensionVersion",
				"title": "Show Pharo Language Server Version",
				"category": "Pharo"
			},
			{
				"command": "pharo.save",
				"title": "Save the Pharo image",
				"category": "Pharo"
			},
			{
				"command": "pharo.createPackage",
				"title": "Create Package",
				"category": "Pharo",
				"icon": "$(package)"
			},
			{
				"command": "pharo.createClass",
				"title": "Create Class",
				"category": "Pharo",
				"icon": "$(symbol-class)"
			},
			{
				"command": "pharo.printIt",
				"title": "Print the result of selected lines",
				"category": "Pharo"
			},
			{
				"command": "pharo.showIt",
				"title": "Show the result of selected lines",
				"category": "Pharo"
			},
			{
				"command": "pharo.doIt",
				"title": "Execute the result of selected lines",
				"category": "Pharo"
			},
			{
				"command": "pharo.installIt",
				"title": "Install the last version of the language server",
				"category": "Pharo"
			},
			{
				"command": "pharo.createProject",
				"title": "Create a new Pharo project",
				"category": "Pharo"
			},
			{
				"command": "pharo.addImageToWorkspace",
				"title": "Add Image To Workspace",
				"category": "Pharo Developer"
			},
			{
				"command": "pharo.executeTest",
				"title": "Execute the test",
				"category": "Pharo",
				"when": false
			},
			{
				"command": "pharo.executeClassTests",
				"title": "Execute all class tests",
				"category": "Pharo",
				"when": false
			},
			{
				"command": "extension.pharo-debug.debugEditorContents",
				"title": "Debug File",
				"category": "Pharo Debug",
				"when": "resourceLangId == markdown",
				"icon": "$(debug-alt)"
			},
			{
				"command": "pharo.openLog",
				"title": "Open Log",
				"category": "Pharo Developer"
			},
			{
				"command": "pharo.openImage",
				"title": "Open Pharo Image",
				"category": "Pharo Developer"
			},
			{
				"command": "pharo.ice.refresh",
				"title": "Refresh Iceberg Repositories",
				"category": "Pharo Git"
			},
			{
				"command": "pharo.ice.commit",
				"title": "Commit Iceberg Repository",
				"category": "Pharo Git",
				"icon": "$(check)"
			},
			{
				"command": "pharo.ice.push",
				"title": "Push Iceberg Repository",
				"category": "Pharo Git",
				"icon": "$(cloud-upload)"
			},
			{
				"command": "pharo.ice.addPackage",
				"title": "Add Package To Iceberg Repository",
				"category": "Pharo Git"
			},
			{
				"command": "pharo.clearLog",
				"title": "Clear Log",
				"category": "Pharo Developer"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "pharo.showIt",
					"when": "editorLangId == pharo",
					"group": "Pharo@1"
				},
				{
					"command": "pharo.printIt",
					"when": "editorLangId == pharo",
					"group": "Pharo@1"
				},
				{
					"command": "pharo.doIt",
					"when": "editorLangId == pharo",
					"group": "Pharo@1"
				}
			],
			"editor/title": [
				{
					"command": "extension.pharo-debug.debugEditorContents",
					"when": "resourceLangId == pharo",
					"group": "Pharo@2"
				}
			],
			"explorer/context": [
				{
					"command": "pharo.createPackage",
					"when": "resourceScheme == pharoImage && explorerResourceIsFolder && (explorerResourceIsRoot || resourcePath == '/')",
					"group": "navigation@1"
				},
				{
					"command": "pharo.createClass",
					"when": "resourceScheme == pharoImage && explorerResourceIsFolder && resourcePath =~ /^\\/[^\\/]+$/",
					"group": "navigation@2"
				}
			],
			"scm/title": [
				{
					"command": "pharo.ice.commit",
					"when": "scmProvider == pharo-iceberg",
					"group": "navigation@1"
				},
				{
					"command": "pharo.ice.push",
					"when": "scmProvider == pharo-iceberg",
					"group": "navigation@2"
				},
				{
					"command": "pharo.ice.refresh",
					"when": "scmProvider == pharo-iceberg",
					"group": "navigation@3"
				}
			]
		},
		"keybindings": [
			{
				"command": "pharo.showIt",
				"key": "ctrl+alt+i"
			},
			{
				"command": "pharo.printIt",
				"key": "ctrl+alt+p"
			},
			{
				"command": "pharo.doIt",
				"key": "ctrl+alt+d"
			}
		],
		"debuggers": [
			{
				"type": "pharodb",
				"label": "Pharo Debug",
				"configurationAttributes": {
					"launch": {
						"required": [
							"program"
						],
						"properties": {
							"program": {
								"type": "string",
								"description": "%debuggers.pharodb.launch.program.description%",
								"default": "${workspaceFolder}/${command:AskForProgramName}"
							}
						}
					}
				}
			}
		],
		"commandPalette": [
			{
				"command": "extension.pharo-debug.debugEditorContents",
				"when": "resourceLangId == pharo"
			}
		],
		"snippets": [
			{
				"language": "pharo",
				"path": "./snippets/snippets.json"
			}
		],
		"walkthroughs": [
			{
				"id": "setup",
				"title": "Set Up PLS",
				"description": "%walkthrough.setup.description%",
				"steps": [
					{
						"id": "downloadImage",
						"title": "Download Pharo Language Server Image",
						"description": "%walkthrough.setup.steps.downloadImage.description%",
						"media": {
							"image": "media/releases.png",
							"altText": ""
						}
					},
					{
						"id": "downloadVM",
						"title": "Download Pharo VM",
						"description": "%walkthrough.setup.steps.downloadVM.description%",
						"media": {
							"image": "media/vms.png",
							"altText": ""
						}
					},
					{
						"id": "modifySetting",
						"title": "Update Setting",
						"description": "%walkthrough.setup.steps.modifySetting.description%",
						"media": {
							"image": "media/pharo-bar.svg",
							"altText": ""
						}
					}
				]
			}
		],
		"notebooks": [
			{
				"type": "moosebook",
				"displayName": "Moosebook",
				"selector": [
					{
						"filenamePattern": "*.moosebook"
					}
				]
			}
		]
	},
	"scripts": {
		"compile": "tsc -b",
		"test": "npm run compile && node ./dist/test/runTest.js",
		"vscode:prepublish": "webpack --mode production",
		"webpack": "webpack --mode development",
		"webpack-dev": "webpack --mode development --watch",
		"test-compile": "tsc -p ./"
	},
	"dependencies": {
		"@microsoft/vscode-file-downloader-api": "^1.0.1",
		"@vscode/debugprotocol": "^1.68.0",
		"vscode-languageclient": "^9.0.1",
		"vscode-languageserver-protocol": "3.17.5"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.10.6",
		"@types/vscode": "^1.96.0",
		"@typescript-eslint/parser": "^8.20.0",
		"@vscode/test-cli": "^0.0.10",
		"@vscode/test-electron": "^2.4.1",
		"eslint": "^9.18.0",
		"mocha": "^11.0.1",
		"ts-loader": "^9.5.2",
		"typescript": "^5.7.3",
		"webpack": "^5.97.1",
		"webpack-cli": "^6.0.1"
	}
}
